{
  "name": "@slatesvideo/cli",
  "version": "0.5.2",
  "description": "Slates CLI: drive the Slates AI video studio from your terminal or let Claude Code shell out to it. Includes the bundled agent skills and an MCP client configurator.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "slates": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EricDisero/slates-mcp.git",
    "directory": "packages/cli"
  },
  "homepage": "https://slates.video",
  "bugs": {
    "url": "https://github.com/EricDisero/slates-mcp/issues"
  },
  "keywords": [
    "slates",
    "cli",
    "mcp",
    "model-context-protocol",
    "ai-video",
    "video-generation",
    "image-generation",
    "claude",
    "claude-code",
    "agent-skills",
    "veo",
    "kling",
    "seedance"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@slatesvideo/shared": "^0.5.2",
    "commander": "^12.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.7.0"
  }
}
